{
  "name": "music-presence-for-discord",
  "version": "0.1.1",
  "description": "Windows tray app that shows the current Apple Music track as Discord Rich Presence.",
  "main": "dist/main/main.js",
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "generate:icon": "node scripts/generate-icon.mjs",
    "clean": "node scripts/clean.mjs",
    "clean:release": "node scripts/clean-release.mjs",
    "prebuild": "npm run clean",
    "predist:win": "npm run clean:release",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dist:win": "npm run generate:icon && npm run build && electron-builder --win nsis portable --publish never"
  },
  "keywords": [
    "discord",
    "rich-presence",
    "apple-music",
    "windows",
    "electron",
    "smtc"
  ],
  "dependencies": {
    "@coooookies/windows-smtc-monitor": "^1.0.12",
    "@xhayper/discord-rpc": "^1.3.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "dev.fjoje.musicpresence",
    "productName": "Music Presence",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "package.json"
    ],
    "asarUnpack": [
      "dist/main/**/*",
      "node_modules/@coooookies/windows-smtc-monitor*/**/*",
      "node_modules/@coooookies/windows-smtc-monitor-win32-*/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable-${arch}.${ext}"
    }
  }
}
